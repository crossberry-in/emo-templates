// List — a vertical list of items.
component List {
  render {
    <Column className="list">
      <Text className="listItem">Item 1</Text>
      <Divider />
      <Text className="listItem">Item 2</Text>
      <Divider />
      <Text className="listItem">Item 3</Text>
    </Column>
  }
}
style "./List.css"
